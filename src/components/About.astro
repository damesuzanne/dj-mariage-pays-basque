---
import { Image } from 'astro:assets';
import richardPhoto from '../assets/richard-dj.png';

const strengths = [
  'Plus de 10 ans d’expérience',
  'Matériel professionnel haut de gamme',
  'Playlist 100% personnalisée',
  'Accompagnement complet, du premier rendez-vous au bal',
];
---

<section class="about" id="atouts">
  <div class="container about-grid">
    <div class="about-visual reveal">
      <div class="frame">
        <Image
          src={richardPhoto}
          alt="Richard aux platines lors d'un mariage, sous les guirlandes lumineuses"
          class="about-photo"
          widths={[480, 760, 1080]}
          sizes="(max-width: 860px) 90vw, 40vw"
          format="webp"
        />
        <p class="frame-caption">Richard · DJ Event</p>
      </div>
    </div>
    <div class="about-content reveal">
      <p class="eyebrow">Votre DJ mariage à Bayonne</p>
      <h2 class="section-title about-title">
        <span>La musique qui <em>vous ressemble</em>,</span>
        <span>du vin d'honneur au bout de la nuit</span>
      </h2>
      <p>
        Passionné de musique depuis toujours, j'ai fait de l'animation de mariages mon métier il y a
        plus de dix ans. Chaque couple est unique : je construis avec vous une ambiance sur mesure,
        du vin d'honneur à l'ouverture de bal, jusqu'à la soirée dansante.
      </p>
      <ul class="strengths">
        {strengths.map((item) => (
          <li>
            <svg viewBox="0 0 20 20" width="18" height="18" aria-hidden="true">
              <path d="M4 10.5l4 4 8-9" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {item}
          </li>
        ))}
      </ul>
      <a href="#devis" class="btn btn-dark">Discutons de votre projet</a>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--cream);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }

  .frame {
    background: var(--night);
    border-radius: var(--radius);
    padding: 1.6rem 1.6rem 1.2rem;
    box-shadow: var(--shadow);
    text-align: center;
    position: relative;
  }

  .frame::before {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(198, 161, 91, 0.4);
    border-radius: calc(var(--radius) - 8px);
    pointer-events: none;
    z-index: 1;
  }

  .about-photo {
    width: 100%;
    height: auto;
    border-radius: calc(var(--radius) - 10px);
    display: block;
    margin-bottom: 1.1rem;
  }

  .frame-caption {
    color: var(--gold-light);
    font-family: var(--font-display);
    font-size: 1.2rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .about-content {
    container-type: inline-size;
  }

  /* Chaque segment du titre reste sur sa propre ligne, sans coupure :
     la taille s'ajuste à la largeur de la colonne (cqw) */
  .about-title {
    font-size: clamp(1.25rem, 5.4cqw, 2.75rem);
  }

  .about-title span {
    display: block;
    white-space: nowrap;
  }

  .about-content p {
    color: var(--ink-soft);
  }

  .strengths {
    list-style: none;
    padding: 0;
    margin: 1.8rem 0 2.4rem;
    display: grid;
    gap: 0.85rem;
  }

  .strengths li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 500;
  }

  .strengths svg {
    flex-shrink: 0;
    color: var(--gold);
  }

  @media (max-width: 860px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
    .about-visual {
      max-width: 380px;
      margin-inline: auto;
    }
  }
</style>
