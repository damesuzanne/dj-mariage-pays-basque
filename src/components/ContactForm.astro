---
import ObfuscatedLink from './ObfuscatedLink.astro';
import ObfuscatedText from './ObfuscatedText.astro';

// Clé publique (site key) du widget Cloudflare Turnstile « mariage dj ».
const TURNSTILE_SITEKEY = '0x4AAAAAADxOwNEZbVFGF9_e';
---

<section class="contact" id="devis">
  <div class="container contact-grid">
    <div class="contact-intro reveal">
      <p class="eyebrow">Devis gratuit</p>
      <h2 class="section-title">Réservez <em>votre date</em></h2>
      <p>
        Votre date, votre lieu, vos envies : je vous réponds sous 24h avec un devis personnalisé et
        gratuit.
      </p>
      <ul class="assurances">
        <li>Réponse sous 24h</li>
        <li>Sans engagement</li>
        <li>Données confidentielles</li>
      </ul>
      <div class="direct" id="contact">
        <ObfuscatedLink type="tel" value="+33684331824" class="direct-item">
          <span class="direct-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M5 4h4l2 5-3 2a13 13 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A17 17 0 0 1 3 6a2 2 0 0 1 2-2z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>
          </span>
          <span>
            <ObfuscatedText value="06 84 33 18 24" tag="strong" />
            <small>7j/7 sur rendez-vous</small>
          </span>
        </ObfuscatedLink>
        <ObfuscatedLink type="email" value="richarddjevent@gmail.com" class="direct-item">
          <span class="direct-icon">
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path d="M3 6h18v12H3zM3 7l9 6 9-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>
          </span>
          <span>
            <ObfuscatedText value="richarddjevent@gmail.com" tag="strong" />
            <small>Bayonne · Pays Basque & Landes</small>
          </span>
        </ObfuscatedLink>
      </div>
    </div>

    <form class="form reveal" id="quote-form" novalidate>
      <input type="hidden" name="subject" value="Nouvelle demande de devis — djmariagepaysbasque.fr" />
      <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />
      <div class="row">
        <label>
          Prénom *
          <input type="text" name="prenom" required autocomplete="given-name" />
        </label>
        <label>
          Nom *
          <input type="text" name="nom" required autocomplete="family-name" />
        </label>
      </div>
      <div class="row">
        <label>
          Email *
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <label>
          Téléphone *
          <input type="tel" name="telephone" required autocomplete="tel" />
        </label>
      </div>
      <div class="row">
        <label>
          Date du mariage *
          <input type="date" name="date" required />
        </label>
        <label>
          Lieu de réception
          <input type="text" name="lieu" placeholder="Ville ou domaine" />
        </label>
      </div>
      <label>
        Votre projet
        <textarea name="message" rows="4" placeholder="Nombre d'invités, ambiance souhaitée, options qui vous intéressent…"></textarea>
      </label>
      <p class="form-error" id="form-error" hidden>Merci de remplir les champs obligatoires (*).</p>
      <p class="form-error" id="form-error-server" hidden>
        Une erreur est survenue lors de l'envoi. Vous pouvez réessayer ou m'écrire directement par
        WhatsApp.
      </p>
      {TURNSTILE_SITEKEY && (
        <div class="cf-turnstile ct-captcha" data-sitekey={TURNSTILE_SITEKEY} data-theme="dark" data-language="fr"></div>
      )}
      <div class="form-actions">
        <button type="submit" class="btn btn-gold" id="submit-btn">Envoyer ma demande</button>
        <button type="button" class="btn btn-whatsapp" id="whatsapp-send">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm4.9 13.9c-.2.6-1.2 1.1-1.7 1.2-.4 0-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.5 2 2.4 1.4 1.2 2.5 1.6 2.9 1.7.3.2.5.1.7-.1l1-1.1c.2-.3.4-.2.7-.1l2.1 1c.3.2.5.3.6.4.1.2.1.7-.1 1.3z" fill="currentColor"/></svg>
          Envoyer via WhatsApp
        </button>
      </div>
      <p class="form-success" id="form-success" hidden>
        Votre demande a bien été envoyée. Merci, je vous réponds sous 24h !
      </p>
      <p class="form-privacy">
        Les informations transmises servent uniquement à traiter votre demande de devis. Elles ne
        sont ni cédées ni revendues. En savoir plus dans notre
        <a href="/politique-de-confidentialite">politique de confidentialité</a>.
      </p>
    </form>
  </div>
</section>

{TURNSTILE_SITEKEY && (
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<style>
  .contact {
    background: var(--night);
    color: var(--white);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }

  .contact .section-title {
    color: var(--white);
  }

  .contact-intro > p {
    color: rgba(255, 255, 255, 0.7);
  }

  .assurances {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    padding: 0;
    margin: 1.6rem 0 2.2rem;
  }

  .assurances li {
    font-size: 0.85rem;
    padding: 0.4rem 0.95rem;
    border-radius: 999px;
    border: 1px solid rgba(198, 161, 91, 0.45);
    color: var(--gold-light);
  }

  .direct {
    display: grid;
    gap: 1rem;
  }

  .direct :global(.direct-item) {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: var(--white);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 0.95rem 1.2rem;
    transition: border-color var(--transition), background var(--transition);
  }

  .direct :global(.direct-item:hover) {
    border-color: rgba(198, 161, 91, 0.6);
    background: rgba(198, 161, 91, 0.08);
  }

  .direct-icon {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: rgba(198, 161, 91, 0.18);
    color: var(--gold-light);
    flex-shrink: 0;
  }

  .direct :global(strong) {
    display: block;
    font-size: 0.98rem;
  }

  .direct :global(small) {
    color: rgba(255, 255, 255, 0.55);
  }

  .form {
    background: var(--white);
    border-radius: var(--radius);
    padding: clamp(1.6rem, 3vw, 2.4rem);
    display: grid;
    gap: 1.1rem;
    box-shadow: var(--shadow);
    color: var(--ink);
  }

  .row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 1.1rem;
  }

  label {
    display: grid;
    gap: 0.4rem;
    font-size: 0.88rem;
    font-weight: 600;
    min-width: 0;
  }

  input,
  textarea {
    font: inherit;
    font-weight: 400;
    padding: 0.75rem 0.95rem;
    border-radius: 10px;
    border: 1.5px solid rgba(16, 21, 34, 0.14);
    background: var(--cream);
    transition: border-color var(--transition);
    width: 100%;
    min-width: 0;
    max-width: 100%;
  }

  /* Safari/iOS donne à input[type=date] une largeur intrinsèque
     qui ignore width:100% sans cette règle */
  input[type='date'] {
    appearance: none;
    -webkit-appearance: none;
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--gold);
  }

  input.invalid {
    border-color: #c65b5b;
  }

  textarea {
    resize: vertical;
  }

  .ct-captcha {
    margin-bottom: 0.4rem;
  }

  .form-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  .btn-whatsapp {
    background: #1fa855;
    color: var(--white);
  }

  .btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
    transform: none;
  }

  .form-error {
    margin: 0;
    color: #c65b5b;
    font-size: 0.9rem;
  }

  .form-success {
    margin: 0;
    color: #2e7d4f;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .form-privacy {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--ink-soft);
  }

  .form-privacy a {
    color: inherit;
    text-decoration: underline;
  }

  .form-privacy a:hover {
    color: var(--gold);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement | null;
  const errorEl = document.getElementById('form-error');
  const successEl = document.getElementById('form-success');
  const whatsappBtn = document.getElementById('whatsapp-send');

  function collect(): Record<string, string> | null {
    if (!form) return null;
    let valid = true;
    const data: Record<string, string> = {};
    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('input, textarea').forEach((field) => {
      field.classList.remove('invalid');
      if (field.required && !field.value.trim()) {
        field.classList.add('invalid');
        valid = false;
      }
      data[field.name] = field.value.trim();
    });
    if (errorEl) errorEl.hidden = valid;
    return valid ? data : null;
  }

  function buildMessage(data: Record<string, string>): string {
    const dateFr = data.date
      ? new Date(`${data.date}T12:00:00`).toLocaleDateString('fr-FR', {
          weekday: 'long',
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        })
      : '';
    return [
      `Bonjour Richard,`,
      ``,
      `Je souhaite vérifier votre disponibilité pour notre mariage.`,
      `• Nom : ${data.prenom} ${data.nom}`,
      `• Date : ${dateFr}`,
      data.lieu ? `• Lieu : ${data.lieu}` : '',
      `• Téléphone : ${data.telephone}`,
      `• Email : ${data.email}`,
      data.message ? `` : '',
      data.message ? `Notre projet : ${data.message}` : '',
    ]
      .filter((line) => line !== '')
      .join('\n');
  }

  const serverErrorEl = document.getElementById('form-error-server');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const data = collect();
    if (!data) return;
    if (serverErrorEl) serverErrorEl.hidden = true;
    if (successEl) successEl.hidden = true;

    const payload = new FormData(form);
    payload.set('message', buildMessage(data));
    payload.set('name', `${data.prenom} ${data.nom}`);

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Envoi en cours…';
    }

    try {
      // Envoi vers notre Worker Cloudflare (valide le captcha, garde la clé secrète)
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: payload,
      });
      const result = await response.json();
      if (result.success) {
        if (successEl) successEl.hidden = false;
        form.reset();
      } else if (serverErrorEl) {
        serverErrorEl.hidden = false;
      }
      (window as any).turnstile?.reset?.();
    } catch {
      if (serverErrorEl) serverErrorEl.hidden = false;
      (window as any).turnstile?.reset?.();
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Envoyer ma demande';
      }
    }
  });

  whatsappBtn?.addEventListener('click', () => {
    const data = collect();
    if (!data) return;
    const text = encodeURIComponent(buildMessage(data));
    const phone = atob('MzM2ODQzMzE4MjQ=');
    window.open(`https://wa.me/${phone}?text=${text}`, '_blank', 'noopener');
    if (successEl) successEl.hidden = false;
  });
</script>
