---
import ObfuscatedLink from './ObfuscatedLink.astro';
import ObfuscatedText from './ObfuscatedText.astro';

const year = new Date().getFullYear();
const waMessage = 'Bonjour Richard, je souhaite des informations pour mon mariage.';
---

<footer class="footer">
  <div class="container footer-grid">
    <div>
      <p class="footer-brand">Richard <em>DJ Event</em></p>
      <p class="footer-desc">
        DJ professionnel spécialisé dans les mariages et événements privés au Pays Basque et dans
        les Landes.
      </p>
      <div class="socials">
        <a href="https://www.instagram.com/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.7"/><circle cx="17.2" cy="6.8" r="1.2" fill="currentColor"/></svg>
        </a>
        <ObfuscatedLink type="tel" value="+33684331824" ariaLabel="Téléphone">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M5 4h4l2 5-3 2a13 13 0 0 0 5 5l2-3 5 2v4a2 2 0 0 1-2 2A17 17 0 0 1 3 6a2 2 0 0 1 2-2z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>
        </ObfuscatedLink>
        <ObfuscatedLink type="wa" value="33684331824" message={waMessage} target="_blank" rel="noopener" ariaLabel="WhatsApp">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm4.9 13.9c-.2.6-1.2 1.1-1.7 1.2-.4 0-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.9 2.1c.1.2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.9 1.5 2 2.4 1.4 1.2 2.5 1.6 2.9 1.7.3.2.5.1.7-.1l1-1.1c.2-.3.4-.2.7-.1l2.1 1c.3.2.5.3.6.4.1.2.1.7-.1 1.3z" fill="currentColor"/></svg>
        </ObfuscatedLink>
        <ObfuscatedLink type="email" value="richarddjevent@gmail.com" ariaLabel="Email">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path d="M3 6h18v12H3zM3 7l9 6 9-6" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></svg>
        </ObfuscatedLink>
      </div>
    </div>
    <nav aria-label="Navigation pied de page">
      <p class="footer-title">Navigation</p>
      <a href="/#accueil">Accueil</a>
      <a href="/#prestations">Prestations</a>
      <a href="/#avis">Témoignages</a>
      <a href="/#contact">Contact</a>
      <a href="/#devis">Demander un devis</a>
    </nav>
    <div>
      <p class="footer-title">Contact</p>
      <p class="footer-line">Bayonne, Pays Basque & Landes</p>
      <p class="footer-line">
        <ObfuscatedLink type="tel" value="+33684331824">
          <ObfuscatedText value="06 84 33 18 24" tag="span" />
        </ObfuscatedLink>
      </p>
      <p class="footer-line">
        <ObfuscatedLink type="email" value="richarddjevent@gmail.com">
          <ObfuscatedText value="richarddjevent@gmail.com" tag="span" />
        </ObfuscatedLink>
      </p>
      <p class="footer-line">7j/7 sur rendez-vous</p>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>© {year} Richard DJ Event. Tous droits réservés.</p>
    <div class="legal">
      <a href="/mentions-legales">Mentions légales</a>
      <a href="/politique-de-confidentialite">Politique de confidentialité</a>
    </div>
  </div>
  <div class="container sub-footer">
    <p>
      Réalisé avec <span class="heart" aria-hidden="true">❤</span> par
      <a href="https://www.htags.fr" target="_blank" rel="noopener">HTAGS</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    background: #0b0f1a;
    color: rgba(255, 255, 255, 0.68);
    padding: 4.5rem 0 2rem;
    font-size: 0.94rem;
  }

  /* Aucun lien souligné dans le footer */
  .footer :global(a) {
    text-decoration: none;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: 1.6rem;
    color: var(--white);
    margin: 0 0 0.8rem;
  }

  .footer-brand em {
    font-style: normal;
    color: var(--gold-light);
  }

  .footer-desc {
    max-width: 320px;
    margin: 0 0 1.4rem;
  }

  .socials {
    display: flex;
    gap: 0.7rem;
  }

  .socials :global(a) {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.75);
    transition: border-color var(--transition), color var(--transition);
  }

  .socials :global(a:hover) {
    border-color: var(--gold);
    color: var(--gold-light);
  }

  .footer-title {
    color: var(--white);
    font-weight: 600;
    margin: 0 0 1rem;
  }

  nav a {
    display: block;
    color: inherit;
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color var(--transition);
  }

  nav a:hover {
    color: var(--gold-light);
  }

  .footer-line {
    margin: 0.3rem 0;
  }

  .footer-line :global(a) {
    color: inherit;
    text-decoration: none;
  }

  .footer-line :global(a:hover) {
    color: var(--gold-light);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.8rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.45);
  }

  .footer-bottom p {
    margin: 0;
  }

  .legal {
    display: flex;
    gap: 1.4rem;
  }

  .legal a {
    color: inherit;
    text-decoration: none;
  }

  .legal a:hover {
    color: var(--gold-light);
  }

  .sub-footer {
    text-align: center;
    padding-top: 1.4rem;
    margin-top: 1.4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .sub-footer p {
    margin: 0;
  }

  .heart {
    color: var(--gold);
  }

  .sub-footer a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
  }

  .sub-footer a:hover {
    color: var(--gold-light);
  }

  @media (max-width: 820px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
