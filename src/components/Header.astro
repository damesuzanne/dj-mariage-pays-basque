---
const links = [
  { href: '/#accueil', label: 'Accueil' },
  { href: '/#prestations', label: 'Prestations' },
  { href: '/#avis', label: 'Témoignages' },
  { href: '/#faq', label: 'FAQ' },
  { href: '/#contact', label: 'Contact' },
];
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <h1 class="brand">
      <a href="/#accueil">
        <span class="brand-mark" aria-hidden="true">R</span>
        <span class="brand-text">
          <span class="brand-name">Richard <em>DJ Event</em></span>
          <span class="brand-tagline">DJ mariage Pays Basque</span>
        </span>
      </a>
    </h1>
    <nav class="nav" id="main-nav" aria-label="Navigation principale">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
      <a href="/#devis" class="btn btn-gold nav-cta">Disponibilités</a>
    </nav>
    <button class="nav-toggle" id="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 50;
    padding: 1.1rem 0;
    transition: background var(--transition), padding var(--transition), box-shadow var(--transition);
  }

  .site-header.is-scrolled {
    background: rgba(16, 21, 34, 0.88);
    backdrop-filter: blur(14px);
    padding: 0.7rem 0;
    box-shadow: 0 10px 30px -18px rgba(0, 0, 0, 0.6);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .brand {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .brand a {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--white);
    font-family: var(--font-body);
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid var(--gold);
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--gold-light);
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .brand-name {
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .brand-name em {
    font-style: normal;
    color: var(--gold-light);
    font-weight: 400;
  }

  .brand-tagline {
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.8rem;
  }

  .nav a:not(.nav-cta) {
    color: rgba(255, 255, 255, 0.82);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color var(--transition);
  }

  .nav a:not(.nav-cta):hover {
    color: var(--gold-light);
  }

  .nav-cta {
    padding: 0.6rem 1.4rem;
    font-size: 0.9rem;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
  }

  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--white);
    transition: transform var(--transition), opacity var(--transition);
  }

  @media (max-width: 820px) {
    .nav {
      position: fixed;
      top: 0;
      right: 0;
      height: 100dvh;
      width: min(320px, 80vw);
      flex-direction: column;
      justify-content: center;
      background: var(--night);
      transform: translateX(100%);
      transition: transform var(--transition);
      box-shadow: -20px 0 60px rgba(0, 0, 0, 0.4);
    }

    .nav.is-open {
      transform: none;
    }

    .nav-toggle {
      display: flex;
      z-index: 60;
    }

    .nav-toggle[aria-expanded='true'] span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav-toggle[aria-expanded='true'] span:nth-child(2) {
      opacity: 0;
    }
    .nav-toggle[aria-expanded='true'] span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('main-nav');

  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 30);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(Boolean(open)));
  });

  nav?.querySelectorAll('a').forEach((link) =>
    link.addEventListener('click', () => {
      nav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );
</script>
