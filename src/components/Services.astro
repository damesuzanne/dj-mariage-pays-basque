---

<section class="services" id="prestations">
  <div class="container">
    <p class="eyebrow reveal">Prestations & options</p>
    <h2 class="section-title reveal">Bien plus qu'un DJ <em>derrière ses platines</em></h2>
    <p class="section-intro reveal">
      Chaque prestation s'adapte à votre lieu, votre programme et vos envies.<br class="break-desktop" />
      Cliquez sur une carte pour voir le détail de ce qui est inclus.
    </p>
    <div class="services-grid">
      {services.map((service) => (
        <button class="card reveal" data-dialog={`dialog-${service.id}`} type="button">
          <div class="card-icon">
            <svg
              viewBox={service.viewBox ?? '0 0 32 32'}
              width="30"
              height="30"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-width="1.4"
              stroke-linecap="round"
              set:html={service.icon}
            />
          </div>
          <h3>{service.title}{service.title2 && <><br />{service.title2}</>}</h3>
          <p>{service.desc}</p>
          <span class="card-more">
            Voir le détail
            <svg viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
              <path d="M5 12h14m-6-6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </button>
      ))}
    </div>
  </div>

  {services.map((service) => (
    <dialog class="service-dialog" id={`dialog-${service.id}`} aria-labelledby={`dialog-title-${service.id}`}>
      <button class="dialog-close" data-close aria-label="Fermer">
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
      <div class="dialog-icon">
        <svg
          viewBox={service.viewBox ?? '0 0 32 32'}
          width="34"
          height="34"
          aria-hidden="true"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
          set:html={service.icon}
        />
      </div>
      <h3 class="dialog-title" id={`dialog-title-${service.id}`}>
        {service.title}{service.title2 && <><br />{service.title2}</>}
      </h3>
      <p class="dialog-desc">{service.modalDesc}</p>
      <p class="dialog-section-title">Ce qui est inclus</p>
      <ul class="dialog-list">
        {service.includes.map((item) => (
          <li>
            <svg viewBox="0 0 20 20" width="16" height="16" aria-hidden="true">
              <path d="M4 10.5l4 4 8-9" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {item}
          </li>
        ))}
      </ul>
      <p class="dialog-section-title">Idéal pour</p>
      <p class="dialog-ideal">{service.ideal}</p>
      <a href="#devis" class="btn btn-gold dialog-cta" data-close>Demander un devis pour cette option</a>
    </dialog>
  ))}
</section>

<style>
  .services {
    /* Semi-transparent : laisse voir la photo sticky derrière la section */
    background: rgba(13, 17, 28, 0.82);
    color: var(--white);
  }

  .services .section-title {
    color: var(--white);
  }

  .services .section-intro {
    color: rgba(255, 255, 255, 0.65);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }

  .card {
    font: inherit;
    text-align: left;
    color: inherit;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    /* Effet verre : flou de la photo sticky visible derrière la carte */
    background: rgba(255, 255, 255, 0.08);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius);
    padding: 2rem 1.7rem;
    box-shadow: 0 14px 40px -20px rgba(0, 0, 0, 0.5);
    transition: transform var(--transition), border-color var(--transition), background var(--transition);
  }

  .card:hover,
  .card:focus-visible {
    transform: translateY(-6px);
    border-color: rgba(198, 161, 91, 0.55);
    background: rgba(198, 161, 91, 0.12);
  }

  .card:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 3px;
  }

  .card-icon {
    width: 54px;
    height: 54px;
    border-radius: 14px;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, rgba(198, 161, 91, 0.25), rgba(198, 161, 91, 0.08));
    color: var(--gold-light);
    margin-bottom: 1.3rem;
  }

  .card h3 {
    color: var(--white);
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
  }

  .card p {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.96rem;
    margin: 0 0 1.2rem;
  }

  .card-more {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--gold-light);
    transition: gap var(--transition);
  }

  .card:hover .card-more {
    gap: 0.75rem;
  }

  /* ===== Modale ===== */
  .service-dialog {
    width: min(560px, calc(100vw - 2.5rem));
    max-height: min(84dvh, 720px);
    border: 1px solid rgba(198, 161, 91, 0.35);
    border-radius: var(--radius);
    background: var(--night);
    color: var(--white);
    padding: 2.4rem 2.2rem 2.2rem;
    box-shadow: 0 40px 90px -30px rgba(0, 0, 0, 0.8);
    scrollbar-width: thin;
    scrollbar-color: rgba(198, 161, 91, 0.45) transparent;
  }

  .service-dialog::backdrop {
    background: rgba(8, 11, 18, 0.72);
    backdrop-filter: blur(6px);
  }

  .service-dialog[open] {
    animation: dialog-in 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @keyframes dialog-in {
    from {
      opacity: 0;
      transform: translateY(18px) scale(0.97);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .service-dialog[open] {
      animation: none;
    }
  }

  .dialog-close {
    position: absolute;
    top: 1.1rem;
    right: 1.1rem;
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: none;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition: border-color var(--transition), color var(--transition);
  }

  .dialog-close:hover {
    border-color: var(--gold);
    color: var(--gold-light);
  }

  .dialog-icon {
    width: 62px;
    height: 62px;
    border-radius: 16px;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, rgba(198, 161, 91, 0.3), rgba(198, 161, 91, 0.1));
    color: var(--gold-light);
    margin-bottom: 1.4rem;
  }

  .dialog-title {
    color: var(--white);
    font-size: 1.75rem;
    margin-bottom: 0.6rem;
  }

  .dialog-desc {
    color: rgba(255, 255, 255, 0.72);
    margin: 0 0 1.6rem;
  }

  .dialog-section-title {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 0.8rem;
  }

  .dialog-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1.6rem;
    display: grid;
    gap: 0.55rem;
  }

  .dialog-list li {
    display: flex;
    align-items: baseline;
    gap: 0.65rem;
    font-size: 0.96rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .dialog-list svg {
    flex-shrink: 0;
    color: var(--gold);
    transform: translateY(2px);
  }

  .dialog-ideal {
    color: rgba(255, 255, 255, 0.72);
    margin: 0 0 1.8rem;
  }

  .dialog-cta {
    width: 100%;
  }

  @media (max-width: 960px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 620px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
    .service-dialog {
      padding: 2rem 1.4rem 1.6rem;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.card[data-dialog]').forEach((card) => {
    const dialog = document.getElementById(card.dataset.dialog ?? '') as HTMLDialogElement | null;
    if (!dialog) return;
    card.addEventListener('click', () => dialog.showModal());
  });

  document.querySelectorAll<HTMLDialogElement>('.service-dialog').forEach((dialog) => {
    dialog.querySelectorAll('[data-close]').forEach((el) =>
      el.addEventListener('click', () => dialog.close())
    );
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });
  });
</script>
