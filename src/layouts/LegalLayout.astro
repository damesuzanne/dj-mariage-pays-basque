---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Layout title={`${title} · Richard DJ Event`} description={`${title} du site djmariagepaysbasque.fr`}>
  <Header />
  <div class="legal-hero">
    <div class="container">
      <a href="/" class="back">← Retour au site</a>
      <h2 class="legal-title">{title}</h2>
      <p class="legal-date">Dernière mise à jour : 4 juillet 2026</p>
    </div>
  </div>
  <main class="container legal-body">
    <slot />
    <a href="/" class="btn btn-dark back-bottom">← Retour au site</a>
  </main>
  <Footer />
</Layout>

<style>
  .legal-hero {
    background: var(--night);
    color: var(--white);
    padding: 8rem 0 3.5rem;
  }

  .legal-title {
    color: var(--white);
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin: 1.2rem 0 0.4rem;
  }

  .legal-date {
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.9rem;
  }

  .back {
    color: var(--gold-light);
    text-decoration: none;
    font-size: 0.92rem;
  }

  .back:hover {
    text-decoration: underline;
  }

  .legal-body {
    padding: 3.5rem 0 5rem;
    max-width: 760px;
  }

  .legal-body :global(h3) {
    font-size: 1.35rem;
    margin-top: 2.4rem;
  }

  .legal-body :global(p),
  .legal-body :global(li) {
    color: var(--ink-soft);
  }

  .legal-body :global(a) {
    color: var(--gold);
  }

  .back-bottom {
    margin-top: 3rem;
  }
</style>
